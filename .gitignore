.venv/
venv/
target/
**/target/
.DS_Store
Thumbs.db
.mcp.json

# 5. Study Assets (TRACKED)
# We explicitly allow these even if they were caught by a broader ignore
!knowledge-base/
!progress-tracker/
!study-plans/
!german-mastery/
!python-mastery/

