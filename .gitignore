# --- STUDY SYSTEM v0.1.0 GITIGNORE ---

# 1. Private Local State (Never Track)
state/
logs/
tmp/
.smart-env/
.obsidian/
**/workspace.json
**/backlink.json
**/graph.json
.env
.env.template
config.json
config_actual.json
connections.json

# 2. Heavy Binaries & Media (Keep Repo Light)
*.pdf
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.webp
*.tar
*.tar.gz
*.tgz
*.zip
*.pdf.txt
